# Database — PostgreSQL required (Prisma provider = postgresql)
# Local example with Docker: postgresql://postgres:postgres@localhost:5432/solkernal
# Production: use your managed Postgres URL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Application
NEXT_PUBLIC_SITE_URL=https://solkernal.xyz

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
NEXT_PUBLIC_SKRN_MINT_ADDRESS=9LnqE9nevGsDHqs7bhJSyMzXwxdQJ2x4ypJNreEZpump

# Day 4 pay-per-run (rug-risk-scanner only). Free trial stays; after guest quota
# users can send paySol SOL to treasury and retry with txSignature.
# Leave TREASURY empty to keep pay path disabled (free trial only).
NEXT_PUBLIC_PROTOCOL_TREASURY=
NEXT_PUBLIC_PAY_PER_RUN_SOL=0.001

# Cloudflare Workers AI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Google AI (Gemini)
GOOGLE_API_KEY=

# Groq
GROQ_API_KEY=

# xAI Grok (OpenAI-compatible: https://api.x.ai/v1)
XAI_API_KEY=

# Optional: web search tool for LLM tool-calling skills
TAVILY_API_KEY=
